{
  "name": "@open-tabletop/desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Signed desktop host for OpenTabletop.",
  "author": "OpenTabletop",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dist": "pnpm --filter @open-tabletop/desktop... build && electron-builder",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@open-tabletop/api": "workspace:*",
    "@open-tabletop/web": "workspace:*",
    "@open-tabletop/tunnel-protocol": "workspace:*",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.5.13",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "org.opentabletop.desktop",
    "productName": "OpenTabletop",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signtoolOptions": {
        "publisherName": "OpenTabletop"
      }
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games"
    }
  }
}
