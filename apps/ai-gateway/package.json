{
  "name": "@open-tabletop/ai-gateway",
  "version": "0.3.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ../../scripts/run-package-manager.mjs --filter @open-tabletop/ai-gateway^... build && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
