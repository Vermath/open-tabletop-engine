{
  "name": "@open-tabletop/web",
  "version": "0.3.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "exports": {
    "./static-runtime": {
      "types": "./dist/server/static-runtime.d.ts",
      "default": "./dist/server/static-runtime.js"
    }
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "start": "node server.mjs",
    "build": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.server.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@open-tabletop/core": "workspace:*",
    "@open-tabletop/dice-engine": "workspace:*",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
