{
  "name": "@open-tabletop/web",
  "version": "0.3.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "exports": {
    "./static-runtime": {
      "types": "./dist/server/static-runtime.d.ts",
      "default": "./dist/server/static-runtime.js"
    }
  },
  "scripts": {
    "dev": "node scripts/dev-or-start.mjs",
    "start": "node server.mjs",
    "build": "node ../../scripts/run-package-manager.mjs --filter @open-tabletop/web^... build && tsc -p tsconfig.json && vite build && tsc -p tsconfig.server.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@open-tabletop/api-client": "workspace:*",
    "@open-tabletop/core": "workspace:*",
    "@open-tabletop/dice-engine": "workspace:*",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
