{
  "name": "@open-tabletop/api",
  "version": "0.3.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": "./dist/server.js",
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "node ../../scripts/run-package-manager.mjs --filter @open-tabletop/api^... build && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "storage:maintenance": "tsx src/sqlite-maintenance-cli.ts",
    "storage:fixture:generate": "node scripts/generate-sqlite-v1-fixture.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@fastify/ajv-compiler": "4.0.5",
    "@fastify/cors": "^10.0.2",
    "@fastify/websocket": "^11.0.1",
    "@open-tabletop/ai-core": "workspace:*",
    "@open-tabletop/api-contracts": "workspace:*",
    "@open-tabletop/codex-app-server-provider": "workspace:*",
    "@open-tabletop/core": "workspace:*",
    "@open-tabletop/dice-engine": "workspace:*",
    "@open-tabletop/plugin-sdk": "workspace:*",
    "@open-tabletop/system-sdk": "workspace:*",
    "@openai/codex": "^0.133.0",
    "fastify": "^5.1.0",
    "pdfjs-dist": "^6.1.200",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
