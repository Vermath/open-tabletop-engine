PORT=4000
HOST=0.0.0.0
VITE_API_URL=http://localhost:4000
OTTE_SQLITE_PATH=storage/opentabletop.sqlite
OTTE_UPLOAD_DIR=uploads
OTTE_AI_PROVIDER=local-echo
# Docker Compose defaults uploaded assets to MinIO/S3. For non-Docker API dev
# without MinIO, omit OTTE_ASSET_STORAGE or set OTTE_ASSET_STORAGE=local.
# OTTE_ASSET_STORAGE=s3
# OTTE_S3_ENDPOINT=http://localhost:9000
# OTTE_S3_BUCKET=opentabletop-assets
# OTTE_S3_REGION=us-east-1
# OTTE_S3_ACCESS_KEY_ID=opentabletop
# OTTE_S3_SECRET_ACCESS_KEY=opentabletop-dev
# OTTE_S3_FORCE_PATH_STYLE=true
API_PORT=4000
WEB_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_USER=opentabletop
POSTGRES_PASSWORD=opentabletop
POSTGRES_DB=opentabletop
MINIO_ROOT_USER=opentabletop
MINIO_ROOT_PASSWORD=opentabletop-dev
