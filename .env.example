PORT=4000
HOST=0.0.0.0
VITE_API_URL=http://127.0.0.1:4000
OTTE_SQLITE_PATH=storage/opentabletop.sqlite
OTTE_UPLOAD_DIR=uploads
OTTE_AI_PROVIDER=codex-app-server
# Comma-separated user ids that can call /api/v1/admin/*.
# OTTE_ADMIN_USER_IDS=usr_demo_gm
# Password reset email delivery. Without OTTE_EMAIL_WEBHOOK_URL, reset emails
# remain in the API outbox for admin inspection.
# OTTE_PASSWORD_RESET_URL=http://localhost:5173/reset-password
# OTTE_PASSWORD_RESET_TTL_MINUTES=60
# OTTE_EMAIL_WEBHOOK_URL=http://localhost:3000/email
# OTTE_EMAIL_WEBHOOK_TOKEN=
# OTTE_EMAIL_WEBHOOK_TIMEOUT_MS=5000
# Legacy x-user-id auth is disabled outside tests unless this is explicitly true.
# OTTE_ALLOW_LEGACY_USER_HEADER=false
# Plugin package trust policy. Set require_trusted in production to block
# unsigned or tampered plugin packages from installation and execution.
# OTTE_PLUGIN_TRUST_POLICY=allow_unsigned
# OTTE_PLUGIN_TRUST_KEYS=trusted-local=replace-with-signing-secret
# Optional comma-separated allowlist of remote plugin registry catalog URLs.
# GMs with plugin.install can sync only these configured registries.
# OTTE_PLUGIN_REGISTRY_URLS=https://plugins.example.com/catalog.json
# OTTE_PLUGIN_REGISTRY_TIMEOUT_MS=5000
# AI provider options:
# - codex-loopback: deterministic Codex App Server adapter smoke provider.
# - codex-app-server: live local Codex app-server WebSocket bridge.
# OpenAI-backed AI uses Codex app-server auth; no OpenAI API key is configured
# or read by the app runtime.
# OTTE_AI_PROVIDER=codex-app-server
# OTTE_CODEX_APP_SERVER_URL=ws://127.0.0.1:4500
# OTTE_CODEX_APP_SERVER_AUTOSTART=true
# Optional absolute/path-like Codex launcher override. Leave unset for local dev.
# OTTE_CODEX_APP_SERVER_COMMAND=path-to-codex.cmd
# OTTE_CODEX_APP_SERVER_LOGIN_TYPE=chatgpt
# OTTE_CODEX_APP_SERVER_CWD=D:\open_tabletop_engine
# OTTE_CODEX_MODEL=
# OTTE_CODEX_IMAGE_MODEL=
# OTTE_CODEX_MODEL_PROVIDER=
# OTTE_AI_PROVIDER_TIMEOUT_MS=30000
# OTTE_AI_IMAGE_PROVIDER=codex-app-server
# OTTE_AI_IMAGE_PROVIDER_TIMEOUT_MS=240000
# OTTE_AI_PROVIDER_RETRY_ATTEMPTS=1
# OTTE_AI_INPUT_TOKEN_COST_USD_PER_1K=
# OTTE_AI_OUTPUT_TOKEN_COST_USD_PER_1K=
# Docker Compose defaults uploaded assets to MinIO/S3. For non-Docker API dev
# without MinIO, omit OTTE_ASSET_STORAGE or set OTTE_ASSET_STORAGE=local.
# OTTE_ASSET_STORAGE=s3
# OTTE_S3_ENDPOINT=http://localhost:9000
# OTTE_S3_BUCKET=opentabletop-assets
# OTTE_S3_REGION=us-east-1
# OTTE_S3_ACCESS_KEY_ID=opentabletop
# OTTE_S3_SECRET_ACCESS_KEY=opentabletop-dev
# OTTE_S3_FORCE_PATH_STYLE=true
# Production asset delivery controls.
# OTTE_ASSET_QUOTA_BYTES=1073741824
# OTTE_ASSET_RETENTION_DAYS=
# OTTE_ASSET_CDN_BASE_URL=https://assets.example.com
# OTTE_ASSET_URL_SIGNING_SECRET=replace-with-random-secret
# OTTE_ASSET_URL_TTL_SECONDS=300
# OTTE_ASSET_URL_MAX_TTL_SECONDS=3600
# Optional external asset trust scanner. The API posts upload metadata and
# contentBase64 before storage writes, after the built-in scanner passes.
# OTTE_ASSET_TRUST_WEBHOOK_URL=https://scanner.example.com/asset-scan
# OTTE_ASSET_TRUST_WEBHOOK_TOKEN=
# OTTE_ASSET_TRUST_TIMEOUT_MS=5000
# OTTE_ASSET_TRUST_FAIL_CLOSED=true
# OTTE_ASSET_TRUST_SCANNER_NAME=external-asset-scanner
# OTTE_ASSET_CLEANUP_GRACE_DAYS=7
# OTTE_ASSET_CLEANUP_INTERVAL_SECONDS=3600
# OTTE_ASSET_CLEANUP_RUN_ON_START=false
# OTTE_ASSET_CLEANUP_DRY_RUN=false
# OTTE_ASSET_CLEANUP_INCLUDE_DELETED=true
# OTTE_ASSET_CLEANUP_INCLUDE_EXPIRED=true
# OTTE_ASSET_CLEANUP_CAMPAIGN_ID=
# OTTE_ASSET_CLEANUP_USER_ID=system_asset_cleanup
# Cloudflare asset edge worker settings. Configure ASSET_URL_SIGNING_SECRET as a Worker secret.
# ASSET_ORIGIN_URL=https://api.example.com
# ASSET_EDGE_ROUTE_PREFIX=
# ASSET_EDGE_MAX_TTL_SECONDS=3600
API_PORT=4000
WEB_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_USER=opentabletop
POSTGRES_PASSWORD=opentabletop
POSTGRES_DB=opentabletop
MINIO_ROOT_USER=opentabletop
MINIO_ROOT_PASSWORD=opentabletop-dev
