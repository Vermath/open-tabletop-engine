PORT=4000
HOST=0.0.0.0
VITE_API_URL=http://127.0.0.1:4000
OTTE_SQLITE_PATH=storage/opentabletop.sqlite
# Keep the newest N in-process SQLite backups (1-365; default 30).
# OTTE_SQLITE_BACKUP_RETENTION_COUNT=30
OTTE_UPLOAD_DIR=uploads
# Bounded campaign archive transport limits. Metadata and aggregate bytes are
# counted uncompressed; non-identity Content-Encoding is rejected.
# OTTE_CAMPAIGN_ARCHIVE_IMPORT_MAX_BYTES=67108864
# OTTE_CAMPAIGN_ARCHIVE_EMBEDDED_ASSET_MAX_BYTES=50331648
# OTTE_CAMPAIGN_ARCHIVE_ASSET_MAX_FILES=10000
OTTE_AI_PROVIDER=codex-app-server
# Comma-separated user ids that can call /api/v1/admin/*.
# OTTE_ADMIN_USER_IDS=usr_demo_gm
# Dedicated background-worker identity. The API receives hashes only; the
# worker receives the matching plaintext token from a secret manager.
# Generate a random token, SHA-256 hash it, and use the same stable worker id
# on each hash entry and worker replica. During rotation, temporarily retain
# both old and new hashes as repeated `worker-id=sha256:...` entries.
# OTTE_WORKER_PROFILE_ENABLED=false
# OTTE_WORKER_TOKEN_HASHES=worker-primary=sha256:replace-with-64-lowercase-hex
# OTTE_WORKER_TOKEN=replace-with-random-worker-token
# OTTE_WORKER_ID=worker-primary
# Deprecated non-production migration bridge only; production hard-refuses it.
# OTTE_WORKER_SESSION_TOKEN=
# OTTE_WORKER_ALLOW_LEGACY_SESSION_TOKEN=false
# Password reset email delivery. Without OTTE_EMAIL_WEBHOOK_URL, reset emails
# remain in the API outbox for admin inspection.
# OTTE_PASSWORD_RESET_URL=http://localhost:5173/reset-password
# OTTE_PASSWORD_RESET_TTL_MINUTES=60
# OTTE_EMAIL_WEBHOOK_URL=http://localhost:3000/email
# OTTE_EMAIL_WEBHOOK_TOKEN=
# OTTE_EMAIL_WEBHOOK_TIMEOUT_MS=5000
# Legacy x-user-id auth is disabled outside tests unless this is explicitly true.
# OTTE_ALLOW_LEGACY_USER_HEADER=false
# Public self-registration stays disabled in production unless explicitly enabled.
# OTTE_PUBLIC_REGISTRATION=false
# Browser auth defaults to HttpOnly SameSite cookies. The Compose profile is
# loopback-only HTTP; hosted deployments should set the public HTTPS origin and
# leave Secure cookies enabled.
# OTTE_WEB_ORIGIN=https://tabletop.example.com
# OTTE_CORS_ALLOWED_ORIGINS=https://tabletop.example.com
# OTTE_TRUSTED_PROXY_HOPS=1
# OTTE_SESSION_COOKIE_SECURE=true
# OTTE_ALLOW_INSECURE_LOCAL_SESSION_COOKIE=false
# Account/network login throttling and bounded asynchronous password work.
# OTTE_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
# OTTE_LOGIN_RATE_LIMIT_ACCOUNT_MAX=10
# OTTE_LOGIN_RATE_LIMIT_NETWORK_MAX=60
# OTTE_LOGIN_RATE_LIMIT_PAIR_MAX=5
# OTTE_LOGIN_RATE_LIMIT_MAX_BUCKETS=50000
# Production and Docker Compose require trusted, reviewed plugin packages by
# default. Local development may explicitly opt into unsigned/unreviewed code.
# OTTE_PLUGIN_TRUST_POLICY=allow_unsigned
# OTTE_PLUGIN_REVIEW_POLICY=allow_unreviewed
# OTTE_PLUGIN_TRUST_KEYS=trusted-local=replace-with-signing-secret
# Optional comma-separated allowlist of remote plugin registry catalog URLs.
# GMs with plugin.install can sync only these configured registries.
# OTTE_PLUGIN_REGISTRY_URLS=https://plugins.example.com/catalog.json
# OTTE_PLUGIN_REGISTRY_TIMEOUT_MS=5000
# OTTE_PLUGIN_DIR=plugins
# AI provider options:
# - codex-loopback: deterministic Codex App Server adapter smoke provider.
# - codex-app-server: live local Codex app-server WebSocket bridge.
# OpenAI-backed AI uses Codex app-server auth; no OpenAI API key is configured
# or read by the app runtime.
# OTTE_AI_PROVIDER=codex-app-server
# Production must explicitly disable AI or configure all four policy controls.
# OTTE_AI_ENABLED=false
# OTTE_AI_CONTEXT_SCOPES=public,gm_private
# OTTE_AI_RETENTION_DAYS=30
# OTTE_AI_PROVIDER_TRANSMISSION_DISCLOSURE=Permission-filtered campaign data in selected scopes is transmitted to the configured AI provider; local retention controls do not delete provider-held data.
# OTTE_CODEX_APP_SERVER_URL=ws://127.0.0.1:4500
# OTTE_CODEX_APP_SERVER_AUTOSTART=true
# Optional absolute/path-like Codex launcher override. Leave unset for local dev.
# OTTE_CODEX_APP_SERVER_COMMAND=path-to-codex.cmd
# OTTE_CODEX_APP_SERVER_LOGIN_TYPE=chatgpt
# OTTE_CODEX_APP_SERVER_CWD=D:\open_tabletop_engine
# OTTE_CODEX_MODEL=
# OTTE_CODEX_IMAGE_MODEL=
# OTTE_CODEX_MODEL_PROVIDER=
# Text/tool turns can legitimately run for several minutes; default 900000 (15 minutes).
# OTTE_AI_PROVIDER_TIMEOUT_MS=900000
# OTTE_AI_IMAGE_PROVIDER=codex-app-server
# OTTE_AI_IMAGE_PROVIDER_TIMEOUT_MS=240000
# OTTE_AI_PROVIDER_RETRY_ATTEMPTS=1
# OTTE_AI_INPUT_TOKEN_COST_USD_PER_1K=
# OTTE_AI_OUTPUT_TOKEN_COST_USD_PER_1K=
# Docker Compose defaults uploaded assets to MinIO/S3. For non-Docker API dev
# without MinIO, omit OTTE_ASSET_STORAGE or set OTTE_ASSET_STORAGE=local.
# OTTE_ASSET_STORAGE=s3
# OTTE_S3_ENDPOINT=http://localhost:9000
# Local Compose only; never enable this for a remote HTTP endpoint.
# OTTE_S3_ALLOW_INSECURE_LOCAL_ENDPOINT=true
# OTTE_S3_BUCKET=opentabletop-assets
# OTTE_S3_REGION=us-east-1
# OTTE_S3_ACCESS_KEY_ID=opentabletop
# OTTE_S3_SECRET_ACCESS_KEY=
# OTTE_S3_FORCE_PATH_STYLE=true
# Production asset delivery controls.
# OTTE_ASSET_QUOTA_BYTES=1073741824
# OTTE_ASSET_RETENTION_DAYS=
# OTTE_ASSET_CDN_BASE_URL=https://assets.example.com
# Docker Compose requires this value because the API runs in production mode.
# OTTE_ASSET_URL_SIGNING_SECRET=replace-with-random-secret
# OTTE_ASSET_URL_TTL_SECONDS=300
# OTTE_ASSET_URL_MAX_TTL_SECONDS=3600
# Optional external asset trust scanner. The API posts upload metadata and
# contentBase64 before storage writes, after the built-in scanner passes.
# OTTE_ASSET_TRUST_WEBHOOK_URL=https://scanner.example.com/asset-scan
# OTTE_ASSET_TRUST_WEBHOOK_TOKEN=
# OTTE_ASSET_TRUST_TIMEOUT_MS=5000
# OTTE_ASSET_TRUST_FAIL_CLOSED=true
# OTTE_ASSET_TRUST_SCANNER_NAME=external-asset-scanner
# OTTE_ASSET_CLEANUP_GRACE_DAYS=7
# OTTE_ASSET_CLEANUP_INTERVAL_SECONDS=3600
# OTTE_ASSET_CLEANUP_RUN_ON_START=false
# OTTE_ASSET_CLEANUP_DRY_RUN=false
# OTTE_ASSET_CLEANUP_INCLUDE_DELETED=true
# OTTE_ASSET_CLEANUP_INCLUDE_EXPIRED=true
# OTTE_ASSET_CLEANUP_CAMPAIGN_ID=
# OTTE_ASSET_CLEANUP_USER_ID=system_asset_cleanup
# Cloudflare asset edge worker settings. Configure ASSET_URL_SIGNING_SECRET as a Worker secret.
# ASSET_ORIGIN_URL=https://api.example.com
# ASSET_EDGE_ROUTE_PREFIX=
# ASSET_EDGE_MAX_TTL_SECONDS=3600
API_PORT=4000
API_BIND_ADDRESS=127.0.0.1
WEB_PORT=5173
WEB_BIND_ADDRESS=127.0.0.1
# OTTE_WEB_SHUTDOWN_TIMEOUT_MS=1000
# Keep the development-credential object store local-only.
INFRA_BIND_ADDRESS=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=opentabletop
MINIO_ROOT_PASSWORD=
# Scheduled SQLite recovery points record the matching asset inventory. Keep
# provider-native MinIO/S3 snapshots in the same recovery window.
# OTTE_SQLITE_BACKUP_RUN_ON_START=true
# OTTE_SQLITE_BACKUP_INTERVAL_SECONDS=86400
# OTTE_SQLITE_BACKUP_REASON=compose-daily
