{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @open-tabletop/web... build",
    "watchPatterns": [
      "apps/web/**",
      "packages/api-client/**",
      "packages/core/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "tsconfig.base.json",
      "railway.web.json"
    ]
  },
  "deploy": {
    "startCommand": "NODE_ENV=production node apps/web/server.mjs",
    "numReplicas": 1,
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "drainingSeconds": 30
  }
}
