{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @open-tabletop/api... build",
    "watchPatterns": [
      "apps/api/**",
      "packages/**",
      "plugins/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "tsconfig.base.json",
      "railway.api.json"
    ]
  },
  "deploy": {
    "startCommand": "NODE_ENV=production OTTE_CODEX_APP_SERVER_COMMAND=apps/api/node_modules/.bin/codex OTTE_CODEX_APP_SERVER_LOGIN_TYPE=chatgptDeviceCode node apps/api/dist/server.js",
    "numReplicas": 1,
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "drainingSeconds": 30
  }
}
