{
  "name": "open-tabletop-engine",
  "version": "0.3.0",
  "private": true,
  "description": "API-first virtual tabletop engine with permissioned plugins and AI assistance.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "e2e": "playwright test && playwright test -c playwright.bootstrap.config.ts",
    "e2e:typecheck": "tsc -p tsconfig.e2e.json",
    "compose:env:init": "node scripts/init-compose-env.mjs",
    "compose:env:test": "node scripts/test-init-compose-env.mjs",
    "compose:recovery:test": "pnpm --filter @open-tabletop/api exec vitest run src/paired-storage-backup.test.ts",
    "gate:fast": "pnpm deployment:smoke && pnpm --filter @open-tabletop/api-contracts test",
    "gate:evidence:record": "node scripts/record-release-evidence.mjs",
    "gate:evidence:check": "node scripts/check-release-gate-evidence.mjs --require-check-pair",
    "gate:evidence:test": "node scripts/test-release-gate-evidence.mjs",
    "gate:diagnostics:test": "node scripts/test-api-gate-diagnostics.mjs",
    "gate:check:cold-pair": "node scripts/record-release-gate-pair.mjs",
    "docs:site": "node scripts/build-docs-site.mjs",
    "docs:site:check": "node scripts/build-docs-site.mjs --check",
    "docs:site:test": "node scripts/test-docs-site.mjs",
    "sbom:test": "node scripts/test-generate-cyclonedx-sbom.mjs",
    "sbom:api": "pnpm --filter @open-tabletop/api list --prod --depth Infinity --json | node scripts/generate-cyclonedx-sbom.mjs --output .codex-artifacts/sbom/open-tabletop-api.cdx.json --platform linux-container",
    "sbom:image:policy:test": "node scripts/test-container-sbom-policy.mjs",
    "sbom:image:api": "node scripts/generate-container-sbom.mjs --dockerfile infra/docker/api.Dockerfile --image open-tabletop-api:sbom-scan --output .codex-artifacts/sbom/open-tabletop-api-image.cdx.json",
    "v1:evidence:check": "node scripts/check-v1-release-evidence.mjs",
    "v1:evidence:templates": "node scripts/v1-evidence-templates.mjs",
    "v1:worktree:check": "node scripts/check-release-worktree-clean.mjs",
    "v1:issues:check": "node scripts/check-v1-open-issues.mjs",
    "v1:completion:audit": "node scripts/v1-completion-audit.mjs",
    "v1:release:handoff": "node scripts/v1-release-handoff.mjs",
    "release:smoke:offline": "pnpm v1:worktree:check && pnpm security:audit && pnpm gate:check:cold-pair && pnpm gate:diagnostics:test && pnpm gate:evidence:test && pnpm e2e && pnpm security:smoke && pnpm migration:smoke && pnpm deployment:smoke && pnpm compose:recovery:test && pnpm perf:smoke && pnpm perf:soak && pnpm perf:capacity && pnpm docs:site:test && pnpm docs:site:check && pnpm compose:env:test && pnpm sbom:test && pnpm sbom:api && pnpm sbom:image:policy:test && pnpm sbom:image:api",
    "release:smoke": "pnpm release:smoke:offline && pnpm v1:issues:check",
    "identity:smoke": "pnpm --filter @open-tabletop/api exec vitest run src/identity-smoke.test.ts",
    "migration:smoke": "pnpm --filter @open-tabletop/api exec vitest run src/migration-smoke.test.ts -t \"migration smoke\"",
    "storage:maintenance": "pnpm --filter @open-tabletop/api storage:maintenance --",
    "deployment:smoke": "pnpm --filter @open-tabletop/api exec vitest run src/deployment-smoke.test.ts",
    "perf:smoke": "pnpm --filter @open-tabletop/api exec vitest run src/performance-smoke.test.ts -t \"performance smoke\"",
    "perf:soak": "pnpm --filter @open-tabletop/api exec vitest run src/performance-smoke.test.ts -t \"performance soak\"",
    "perf:capacity": "pnpm --filter @open-tabletop/api exec tsx src/small-group-capacity-cli.ts",
    "security:audit": "node scripts/audit-production-dependencies.mjs",
    "security:smoke": "pnpm --filter @open-tabletop/api exec vitest run src/security-smoke.test.ts",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm e2e:typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.21",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3"
  }
}
