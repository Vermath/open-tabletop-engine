{
  "name": "open-tabletop-engine",
  "version": "0.1.0",
  "private": true,
  "description": "API-first virtual tabletop engine with permissioned plugins and AI assistance.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@8.7.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
