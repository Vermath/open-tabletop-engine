{
  "name": "open-tabletop-engine",
  "version": "0.3.0",
  "private": true,
  "description": "API-first virtual tabletop engine with permissioned plugins and AI assistance.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@8.7.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "e2e": "playwright test && playwright test -c playwright.bootstrap.config.ts",
    "docs:site": "node scripts/build-docs-site.mjs",
    "docs:site:check": "node scripts/build-docs-site.mjs --check",
    "docs:site:test": "node scripts/test-docs-site.mjs",
    "v1:evidence:check": "node scripts/check-v1-release-evidence.mjs",
    "v1:evidence:test": "node scripts/test-v1-release-evidence.mjs",
    "v1:evidence:templates": "node scripts/v1-evidence-templates.mjs",
    "v1:release:handoff": "node scripts/v1-release-handoff.mjs",
    "release:smoke": "pnpm check && pnpm e2e && pnpm security:smoke && pnpm migration:smoke && pnpm deployment:smoke && pnpm perf:smoke && pnpm docs:site:test && pnpm v1:evidence:test",
    "identity:smoke": "pnpm --filter @open-tabletop/api test -- --run src/identity-smoke.test.ts",
    "migration:smoke": "pnpm --filter @open-tabletop/api test -- --run -t \"migration smoke\"",
    "deployment:smoke": "pnpm --filter @open-tabletop/api test -- --run -t \"deployment smoke\"",
    "perf:smoke": "pnpm --filter @open-tabletop/api test -- --run -t \"performance smoke\"",
    "security:smoke": "pnpm --filter @open-tabletop/api test -- --run -t \"security smoke\"",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
