{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @open-tabletop/worker... build",
    "watchPatterns": [
      "apps/worker/**",
      "packages/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "turbo.json",
      "tsconfig.base.json",
      "railway.worker.json"
    ]
  },
  "deploy": {
    "startCommand": "OTTE_WORKER_LEASE_POLL=true node apps/worker/dist/index.js",
    "numReplicas": 1,
    "restartPolicyType": "ALWAYS",
    "drainingSeconds": 30
  }
}
