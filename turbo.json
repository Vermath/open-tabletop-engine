{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "OTTE_PACKAGE_MANAGER_COMMAND",
    "OTTE_PACKAGE_MANAGER_SHIM_DIR"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
